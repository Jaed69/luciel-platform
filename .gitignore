# Secrets — never commit
.env
ssh-key-*.key
ssh-key-*.key.pub
*.key
*.key.pub
*.pem
*.ppk

# Let's Encrypt cert store (contains private key material — D-13, D-20, T-01-03)
traefik/letsencrypt/
traefik/acme.json

# Node / Astro build artifacts
node_modules/
dist/
.astro/
.next/
next-env.d.ts
*.log

# Python build artifacts
__pycache__/
*.pyc
*.pyo
.venv/

# Versioned (do NOT ignore):
#   traefik/traefik.yml
#   docker-compose.yml
