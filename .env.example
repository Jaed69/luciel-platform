# .env.example — Reference for required environment variables.
# NEVER commit `.env` to git. In production the VPS `.env` is regenerated on
# every CI deploy from **GitHub repository secrets** (see
# `.github/workflows/release.yml` deploy job). To add a new variable:
#   1. Add it to this file (reference)
#   2. `gh secret set NAME -b "value"`
#   3. Add it to the deploy job `env:` + heredoc body in release.yml
#   4. No manual edits on the VPS — they will be wiped on the next deploy.

# NOTE: ACME email / caServer / staging-vs-prod are now configured in
# traefik/traefik.yml directly (Traefik v3 treats config-file and CLI args
# as mutually exclusive, so env interpolation via compose command: was
# silently ignored). Flip staging→prod by editing the caServer line there.

# Traefik dashboard basic-auth credentials (D-17)
# Generate password hash:  htpasswd -nbB admin 'your-password'
# (no htpasswd? use:  openssl passwd -apr1 'your-password'  — Traefik basicauth accepts MD5 apr1)
# IMPORTANT: escape every $ as $$ in the value below, or Compose will try to
# interpolate $-prefixed fragments as variable names (and silently empty them).
# Example: $$apr1$$salt$$hash  (not $apr1$salt$hash, not '$apr1$salt$hash')
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASS_HASH=

# GitHub Container Registry (D-10, INFR-05)
# Owner of the GHCR namespace — must be lowercase (GitHub case-folds usernames).
# Used in docker-compose image: refs (`ghcr.io/${GHCR_OWNER}/luciel-platform-*`).
# Has a `:-jaed69` default in compose so local/dev runs without setting it.
GHCR_OWNER=jaed69
# PAT for pulling private images — leave empty if GHCR package is public.
# When set, the deploy job runs `docker login ghcr.io` before `compose pull`.
GHCR_PAT=

# Tours API + Web (Phase 02.1)
# JWT secret compartido entre tours-web (NextAuth sign) y tours-api (pyjwt verify).
# Generar con:  openssl rand -base64 32   (≥32 bytes; el verificador pyjwt pide al menos 32)
# IMPORTANTE: usar el MISMO valor en tours-web y tours-api (D-02 — si difieren los JWTs se rechazan).
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://tours.luciel.dev
# Path interno del contenedor tours-api, no el path del host (D-03).
# Named Docker volume `tours-db-data` is mounted at /data; this URI lands the file there.
# Hardcoded in docker-compose.yml — NOT an env var on the host. Listed here for reference only.
DATABASE_URL=sqlite+aiosqlite:////data/tours.db
JWT_ALGORITHM=HS256
# Solo para debug local — en prod tours-api queda interno (D-01) y tours-web solo sale por Traefik HTTPS.
TOURS_WEB_PORT=3000
TOURS_API_PORT=8000
# Password inicial del admin seed (admin@tours.luciel.dev). Cambiar en prod.
# El seed corre solo si la base de datos está vacía (idempotente).
ADMIN_INITIAL_PASSWORD=change-me
