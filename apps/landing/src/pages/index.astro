---
import Layout from '../layouts/Layout.astro';

// ponytail: static placeholder, zero client JS. Real content lands Phase 2.
const repoUrl = 'https://github.com/Jaed69/luciel-platform';
---

<Layout title="luciel.dev — under construction">
  <main class="min-h-screen flex flex-col items-center justify-center px-md py-xl">
    <span class="inline-flex items-center bg-coral text-on-dark font-mono text-mono-label uppercase rounded-full px-lg py-xs" style="letter-spacing: 0.28px;">
      Under construction
    </span>

    <h1 class="font-display text-section-heading mt-xl text-center" style="line-height: 1.2; letter-spacing: -0.48px;">
      luciel.dev
    </h1>

    <h2 class="font-display text-feature-heading mt-md text-center" style="line-height: 1.3;">
      Under construction
    </h2>

    <p class="font-display text-feature-heading mt-lg text-center" style="line-height: 1.3;">
      Nothing here yet
    </p>

    <p class="text-body mt-md max-w-prose text-center" style="line-height: 1.5;">
      luciel.dev is being built. Real content — a personal intro, technical blog,
      and tool directory — lands in the next phase. Follow the build on GitHub.
    </p>

    <a href={repoUrl} class="text-action-blue underline mt-lg text-button" style="font-weight: 500;">
      View source on GitHub
    </a>
  </main>
</Layout>
