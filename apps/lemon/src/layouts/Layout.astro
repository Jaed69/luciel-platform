---
import '../styles/tokens.css';
import '../styles/lemon-theme.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'lemon.luciel.dev',
  description = 'Un libro digital de recuerdos.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Página personal, no listada — nunca debe indexarse ni aparecer en buscadores. -->
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="lemon-body">
    <img src="/assets/sticker-star-yellow.png" alt="" class="lemon-sticker" style="width:48px; top:70px; left:calc(50% - 20px); animation-delay:0s;" aria-hidden="true" />
    <img src="/assets/sticker-smiley.png" alt="" class="lemon-sticker" style="width:56px; bottom:60px; right:40px; animation-delay:1.2s;" aria-hidden="true" />
    <img src="/assets/sticker-star-black.png" alt="" class="lemon-sticker" style="width:34px; top:120px; right:90px; animation-delay:2s;" aria-hidden="true" />
    <slot />
  </body>
</html>

