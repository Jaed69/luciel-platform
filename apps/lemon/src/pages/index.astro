---
import Layout from '../layouts/Layout.astro';
import VideoCard from '../components/VideoCard.astro';
import { sections } from '../data/videos';
---

<Layout title="lemon.luciel.dev" description="Un libro digital de videos.">
  <main class="min-h-screen px-md py-xl max-w-4xl mx-auto">
    <header class="text-center py-xl">
      <h1 class="font-display text-section-heading" style="line-height: 1.2; letter-spacing: -0.48px;">
        🍋 lemon
      </h1>
      <p class="text-body mt-md max-w-prose mx-auto">
        Un libro digital de videos — momentos que se van agregando con el tiempo.
      </p>
    </header>

    <nav class="flex flex-wrap gap-sm justify-center py-lg" aria-label="Secciones">
      {sections.map((section) => (
        <a href={`#${section.slug}`} class="text-button rounded-pill border border-hairline px-lg py-xs">
          {section.title}
        </a>
      ))}
    </nav>

    {sections.map((section) => (
      <section id={section.slug} class="py-xl">
        <h2 class="font-display text-feature-heading" style="line-height: 1.3;">
          {section.title}
        </h2>
        <div class="grid gap-lg mt-lg" style="grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));">
          {section.videos.map((video) => (
            <VideoCard
              title={video.title}
              youtubeId={video.youtubeId}
              date={video.date}
              description={video.description}
            />
          ))}
        </div>
      </section>
    ))}
  </main>
</Layout>
